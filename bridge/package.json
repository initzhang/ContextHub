{
  "name": "contexthub",
  "version": "0.1.0",
  "description": "OpenClaw context-engine plugin: bridges the ContextHub Python sidecar into the OpenClaw runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "typescript": "^5.4"
  }
}
